# =========================
# ANSIBLE
# =========================

# Vault passwords / secrets ⚠️
.vault_pass
vault_pass.txt
*.vault

# Retry files (created when a play fails)
*.retry

# Logs
ansible.log

# Facts cache (if using jsonfile/redis/etc.)
.fact_cache/
facts_cache/
*.fact

# Inventory backups / temp
inventory.bak
inventory.ini.bak

# Roles downloaded via ansible-galaxy
roles/

# Collections (if installed locally)
collections/

# Molecule (testing framework)
.molecule/
.molecule_cache/

# Python virtual envs (common with ansible setups)
.venv/
venv/

# SSH artifacts (sometimes accidentally generated)
*.retry
*.pem
